# Humble Halal — environment variables (audit CP4).
# Copy to .env.local and fill in. Values here are PLACEHOLDERS — never commit real secrets.
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only.
# Platform-injected vars (NODE_ENV, VERCEL_OIDC_TOKEN, GITHUB_OUTPUT) are NOT listed.

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.humblehalal.com
SITE_URL=https://www.humblehalal.com            # used by scripts (schema/link checks)

# ── Analytics / Tag Manager ───────────────────────────────────────────────────
# GTM container id (GTM-XXXXXXX). When set, GTM loads with Consent Mode v2
# defaults-denied; GA4/Meta/TikTok/LinkedIn/Ads/Clarity are all managed inside
# the container (see docs/tracking-measurement-setup.md). Blank = disabled.
NEXT_PUBLIC_GTM_ID=

# Google AdSense publisher id (ca-pub-XXXXXXXXXXXXXXXX). Blank = AdSense OFF: ad
# slots serve direct sponsors only and collapse cleanly when unbooked. Set this
# AFTER the AdSense account is approved, then paste each slot's data-ad-slot id
# into Admin → Featured & ads → Placements. Brand-safety category blocks are
# configured in the AdSense dashboard — mirror lib/ad-safety.ts (see runbook).
NEXT_PUBLIC_ADSENSE_CLIENT=

# Phase 2 — server-side conversions (Meta CAPI + TikTok Events API via
# app/api/track). Browser pixel + server event share one event_id → dedupe.
NEXT_PUBLIC_SERVER_EVENTS=              # "1" to forward client conversions to /api/track; blank = off
META_PIXEL_ID=                         # server copy of the Meta pixel id
META_CAPI_ACCESS_TOKEN=                # SECRET — Events Manager › Conversions API
META_TEST_EVENT_CODE=                  # optional — Events Manager › Test events
TIKTOK_PIXEL_ID=                       # TikTok pixel / event-source id
TIKTOK_EVENTS_ACCESS_TOKEN=            # SECRET — TikTok Events API token
TIKTOK_TEST_EVENT_CODE=                # optional — TikTok test-event code

# ── Clerk (authentication + security; the database stays Supabase) ────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=              # pk_... — browser-safe
CLERK_SECRET_KEY=                               # SECRET — server-only
CLERK_WEBHOOK_SIGNING_SECRET=                   # whsec_... — verifies /api/webhooks/clerk (user.created)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login            # custom in-app sign-in screen
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login

# ── Supabase (database only; auth is Clerk via Third-Party Auth) ──────────────
# Configure Supabase → Authentication → Third-Party Auth → Clerk (paste the
# Clerk issuer/Frontend-API domain) so Postgres trusts Clerk JWTs and reads the
# user id from auth.jwt()->>'sub'. Run migration 0031_clerk_auth.sql.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=                  # public anon key (RLS-restricted; ships to browser)
SUPABASE_SERVICE_ROLE_KEY=                      # SECRET — bypasses RLS; server-only, never expose

# ── Supabase Edge Functions (Deno; deployed separately via `npm run deploy:functions`) ──
# Set on the SUPABASE side via `supabase secrets set` — NOT Vercel. SUPABASE_URL +
# SUPABASE_SERVICE_ROLE_KEY are auto-injected into the function runtime; reuse
# RESEND_API_KEY + AI_GATEWAY_API_KEY there too. The DB Webhooks send this shared
# secret as the `x-webhook-secret` header; the functions verify it (verify_jwt=off).
WEBHOOK_SHARED_SECRET=                          # SECRET — shared between the Supabase DB Webhooks and the Edge Functions

# ── LiteAPI (hotels + flights; merchant of record) ────────────────────────────
LITEAPI_ENV=sandbox                             # sandbox | prod
LITEAPI_SAND_KEY=                               # sandbox API key
LITEAPI_PROD_KEY=                               # production API key
LITEAPI_WEBHOOK_SECRET=                         # verifies LiteAPI webhooks (HMAC-SHA256 signature, bearer fallback)
LITEAPI_WEBHOOK_SIGNATURE_HEADER=              # optional — exact signature header from LiteAPI Webhooks app (else common names probed)
NEXT_PUBLIC_LITEAPI_PUBLIC_KEY=                 # legacy/optional — Payment SDK uses 'sandbox'/'live' from LITEAPI_ENV

# ── Stripe (Connect + subscriptions + tickets) ────────────────────────────────
STRIPE_SECRET_KEY=                              # SECRET
STRIPE_WEBHOOK_SECRET=                          # SECRET — verifies the single /api/webhooks/stripe endpoint
STRIPE_PRICE_FEATURED_M=                        # price IDs for listing plans (monthly/yearly)
STRIPE_PRICE_FEATURED_Y=
STRIPE_PRICE_PREMIUM_M=
STRIPE_PRICE_PREMIUM_Y=
STRIPE_PRICE_VERIFIED_M=
STRIPE_PRICE_VERIFIED_Y=
STRIPE_PRICE_VERIFIED_FOUNDING_Y=               # founding-member yearly rate (lib/plans FOUNDING) — banner claimable only when set
STRIPE_PRICE_LEADS_M=                           # Lead Inbox monthly (lib/lead-plans) — required before PAID_LEADS_ENABLED
STRIPE_PRICE_LEADS_FOUNDING_M=                  # founding lead rate (first 25/vertical) — founding claimable only when set

# ── Payment / booking kill-switches (server-side gates; unset = OFF) ──────────
PAID_HOTELS_ENABLED=                            # 1 to enable live hotel booking
PAID_FLIGHTS_ENABLED=                           # 1 to enable live flight booking (needs Vercel Pro + LiteAPI GA)
PAID_TICKETS_ENABLED=                           # 1 to enable paid event tickets (Connect)
PAID_PLANS_ENABLED=                             # 1 to enable paid listing plans
PAID_ADS_ENABLED=                               # 1 to enable paid sponsored ads
PAYNOW_ENABLED=                                 # 1 to offer PayNow at ticket checkout (activate PayNow in the Stripe dashboard first; safe to flip early — checkout retries card-only)
PAID_LEADS_ENABLED=                             # 1 to charge for lead subscriptions (needs STRIPE_PRICE_LEADS_M). Off = leads route free during beta

# ── Other feature flags (unset = OFF) ─────────────────────────────────────────
CERT_VAULT_ENABLED=
SEMANTIC_SEARCH_ENABLED=
RAMADAN_MODE_ENABLED=
AI_CONCIERGE_ENABLED=
LEAD_ROUTING_ENABLED=                           # 1 to enable the lead marketplace (owner Leads tab, admin pipeline, quote routing). Ship dark; flip after migration 0046
LEAD_AUTO_ROUTE=                                # 1 to auto-route new leads inline (phase 4); unset = admin approves each route first

# INVERTED flag: the pre-launch banner on the homepage shows UNLESS this is set
# to exactly "0". Set NEXT_PUBLIC_PRELAUNCH=0 (and redeploy) to hide it at launch.
NEXT_PUBLIC_PRELAUNCH=

# ── AI (Vercel AI Gateway) ────────────────────────────────────────────────────
AI_GATEWAY_API_KEY=                             # without it, AI search degrades to deterministic fallback
AI_MODEL=                                       # optional override (default model)
AI_MODEL_FAST=                                  # optional override (fast model)

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=                                 # transactional email (tickets, alerts)
EMAIL_FROM=Humble Halal <hello@humblehalal.com>
EMAIL_REPLY_TO=                                 # optional Reply-To (defaults to hello@humblehalal.com)
CONTACT_INBOX=                                  # where contact-form submissions go
BEEHIIV_API_KEY=                                # newsletter
BEEHIIV_PUBLICATION_ID=

# ── Cron + rate limiting (infra) ──────────────────────────────────────────────
CRON_SECRET=                                    # SECRET — fail-closed in prod; guards /api/cron/* (and the GitHub Action)
UPSTASH_REDIS_REST_URL=                         # rate limiting + read-through cache (fails open if unset)
UPSTASH_REDIS_REST_TOKEN=

# ── Misc ──────────────────────────────────────────────────────────────────────
ONEMAP_TOKEN=                                   # Singapore OneMap (maps / geocoding)
BOOKING_WEBHOOK_URL=                            # optional outbound CRM webhook on hotel booking

# ── Sandbox flight-check script (scripts/flight-sandbox-check) ────────────────
FLIGHT_CHECK_FROM=SIN
FLIGHT_CHECK_TO=JED
FLIGHT_CHECK_DATE=                              # YYYY-MM-DD (default ~30 days out)
