{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "bash scripts/ignore-build.sh",
  "git": {
    "deploymentEnabled": {
      "master": true,
      "**": false
    }
  },
  "crons": [
    { "path": "/api/cron/recheck-certs", "schedule": "0 3 * * 1" },
    { "path": "/api/cron/freshness-audit", "schedule": "0 4 * * 1" },
    { "path": "/api/cron/refresh-stats", "schedule": "0 2 * * *" },
    { "path": "/api/cron/social-enqueue", "schedule": "0 1 * * *" },
    { "path": "/api/cron/social-dispatch", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/owner-alerts", "schedule": "0 0 * * 1" },
    { "path": "/api/cron/owner-monthly-report", "schedule": "0 1 1 * *" },
    { "path": "/api/cron/index-health", "schedule": "0 6 * * *" },
    { "path": "/api/cron/flight-retry", "schedule": "0 5 * * *" },
    { "path": "/api/cron/fare-alerts", "schedule": "0 7 * * *" },
    { "path": "/api/cron/event-payouts", "schedule": "30 6 * * *" },
    { "path": "/api/cron/ads-lifecycle", "schedule": "45 0 * * *" },
    { "path": "/api/cron/lead-cascade", "schedule": "30 2 * * *" },
    { "path": "/api/cron/review-triage", "schedule": "15 1 * * *" },
    { "path": "/api/cron/event-reminders", "schedule": "0 1 * * *" },
    { "path": "/api/cron/lead-retention", "schedule": "0 4 * * 2" },
    { "path": "/api/cron/hawker-sync", "schedule": "0 5 * * 3" },
    { "path": "/api/cron/verdict-drafts", "schedule": "20 3 * * *" },
    { "path": "/api/cron/crm-sync", "schedule": "*/15 * * * *" }
  ]
}
