# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated staging data (open-data seeds)
/data/staging/

# automation job outputs (local Claude jobs + CI scratch)
/reports/
/logs/
/lychee/
sitemap-prev.txt
sitemap-diff.md
.lighthouseci/
/test-results/
/playwright-report/

# LiteAPI reference + local Claude settings (may contain keys)
lite_api.postman_collection.json
.claude/settings.json
.playwright-mcp/

# Supabase CLI local artifacts
supabase/.temp/

# clerk configuration (can include secrets)
/.clerk/
